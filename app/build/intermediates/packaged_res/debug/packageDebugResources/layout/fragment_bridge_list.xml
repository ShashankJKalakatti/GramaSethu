<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@color/background">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:background="@color/primary" android:orientation="vertical" android:padding="16dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Bridge Status" android:textColor="@color/white"
            android:textSize="20sp" android:textStyle="bold"/>
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginTop="10dp" android:hint="Search bridge, village, district…"
            app:boxBackgroundColor="@color/white"
            app:boxCornerRadiusTopStart="24dp" app:boxCornerRadiusTopEnd="24dp"
            app:boxCornerRadiusBottomStart="24dp" app:boxCornerRadiusBottomEnd="24dp"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.Dense">
            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_search"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:inputType="text" android:textSize="14sp"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <HorizontalScrollView android:layout_width="match_parent" android:layout_height="wrap_content"
        android:scrollbars="none" android:background="@color/surface">
        <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:orientation="horizontal" android:padding="10dp">
            <com.google.android.material.chip.Chip android:id="@+id/chip_all"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="All" android:checkable="true" android:checked="true"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_open"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Open" android:checkable="true" android:layout_marginStart="6dp"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_damaged"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Damaged" android:checkable="true" android:layout_marginStart="6dp"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_submerged"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Submerged" android:checkable="true" android:layout_marginStart="6dp"/>
            <com.google.android.material.chip.Chip android:id="@+id/chip_unknown"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Unknown" android:checkable="true" android:layout_marginStart="6dp"/>
        </LinearLayout>
    </HorizontalScrollView>

    <androidx.recyclerview.widget.RecyclerView android:id="@+id/recycler_bridges"
        android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:clipToPadding="false" android:paddingBottom="8dp"/>

    <TextView android:id="@+id/text_empty"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:gravity="center" android:padding="32dp" android:text="No bridges found"
        android:textSize="16sp" android:textColor="@color/text_secondary" android:visibility="gone"/>
</LinearLayout>
